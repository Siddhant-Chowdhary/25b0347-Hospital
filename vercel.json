{
    "services": {
        "frontend": {
            "root": "25B0347",
            "framework": "vite"
        },
        "backend": {
            "root": "hospital-api",
            "entrypoint": "server.js"
        }
    },
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
